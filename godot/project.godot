; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Blast Brigade"
config/description="Wave-based direct-fire TD. Cannon shoots bombs; enemies drop currency on kill; currency spawns heroes. Forked from Pop Brigade v2."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameConfig="*res://scripts/GameConfig.gd"
RunState="*res://scripts/RunState.gd"
MetaState="*res://scripts/MetaState.gd"
Telemetry="*res://scripts/Telemetry.gd"
VFX="*res://scripts/VFX.gd"
SFX="*res://scripts/SFX.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1560
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
